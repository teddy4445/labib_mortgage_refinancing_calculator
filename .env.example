APP_ENV=development
DEBUG=true
FRONTEND_URL=http://localhost:8000
API_CONTRACT_VERSION=2026-04-phase5
DATABASE_URL=sqlite+aiosqlite:///./labib_mortgage.db

SENDGRID_API_KEY=
EMAIL_FROM=no-reply@labib.example
EMAIL_FROM_NAME=Labib Mortgage Monitor

CAPTCHA_PROVIDER=turnstile
CAPTCHA_SECRET_KEY=
CAPTCHA_VERIFY_URL=https://challenges.cloudflare.com/turnstile/v0/siteverify

RATE_LIMIT_REQUESTS=20
RATE_LIMIT_WINDOW_SECONDS=60

ANALYSIS_DEFAULT_ANNUAL_DISCOUNT_RATE=4.0
ANALYSIS_PRIME_MODEST_ANNUAL_INCREASE=0.25
ANALYSIS_PARTIAL_SUBSET_LIMIT=64

MARKET_DATA_USE_STATIC_FALLBACKS=true
MARKET_DATA_FETCH_TIMEOUT_SECONDS=20
MARKET_DATA_RETRY_COUNT=2
MARKET_DATA_ENABLE_BOI_BASE_RATE=true
MARKET_DATA_ENABLE_BOI_MORTGAGE_RATE_BUCKETS=true
MARKET_DATA_ENABLE_CPI_SERIES=true
MARKET_DATA_ENABLE_INFLATION_EXPECTATIONS=true
MARKET_DATA_BOI_BASE_RATE_URL=
MARKET_DATA_BOI_MORTGAGE_RATE_BUCKETS_URL=
MARKET_DATA_CPI_SERIES_URL=
MARKET_DATA_INFLATION_EXPECTATIONS_URL=
MARKET_DATA_ANOMALY_BASE_RATE_JUMP_PERCENT=2.0
MARKET_DATA_ANOMALY_BUCKET_RATE_JUMP_PERCENT=3.0
MARKET_DATA_ANOMALY_CPI_JUMP_RATIO=0.08
MARKET_DATA_ANOMALY_INFLATION_JUMP_PERCENT=4.0
